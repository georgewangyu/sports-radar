# GitHub token must stay server-side. Do not prefix with NEXT_PUBLIC_.
# Fine-grained PAT permissions: target repos -> Issues: Read and write.
GITHUB_TOKEN=<server-side-github-token>
GITHUB_OWNER=georgewangyu

# Shared audience issue targets.
GITHUB_REPO=audience-request-form
GITHUB_PRIVATE_REPO=audience-private-intake

# Optional.
GITHUB_API_VERSION=2022-11-28
SPORTS_RADAR_REQUEST_ALLOWED_ORIGIN=

# Server-side lead capture for the install unlock form.
# Create public.radar_leads with docs/radar-leads-supabase.sql.
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<server-side-service-role-key>
